# Database (corp-graph Postgres)
CORPGRAPH_DB_URL=postgresql://corpgraph:corpgraph@localhost:5432/corpgraph

# API keys
CRAWL4AI_API_KEY=
FIRECRAWL_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=
EXA_API_KEY=

# Per-stage models (any litellm-supported string)
DISCOVER_MODEL=bedrock/us.anthropic.claude-opus-4-6-20250219-v1:0
EXTRACT_MODEL=bedrock/us.anthropic.claude-opus-4-6-20250219-v1:0
MERGE_MODEL=openai/gpt-5-mini
QA_MODEL=bedrock/us.anthropic.claude-opus-4-6-20250219-v1:0

# Search provider: exa | brave | tavily | openai
SEARCH_PROVIDER=exa
